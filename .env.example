# ═══════════════════════════════════════════════════════
# .env.example — LLM EBIOS RM
# Copy to .env and customize. DO NOT commit .env
# ═══════════════════════════════════════════════════════

# ── Ollama ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=mistral-ebios-rm
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Model paths ─────────────────────────────────────────
BASE_MODEL_PATH=./models/Mistral-7B-Instruct-v0.3
LORA_WEIGHTS_PATH=./finetuning/checkpoints/best
GGUF_MODEL_PATH=./finetuning/output/mistral-7b-ebios-rm-q4_k_m.gguf

# ── ChromaDB ────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=ebios_rm_corpus

# ── Corpus ──────────────────────────────────────────────
CORPUS_TRAIN_PATH=./corpus/datasets/train.jsonl
CORPUS_VAL_PATH=./corpus/datasets/validation.jsonl
CORPUS_TEST_PATH=./corpus/datasets/test.jsonl

# ── Application ─────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ── Evaluation ──────────────────────────────────────────
EVAL_GLOBAL_THRESHOLD=0.80
EVAL_TERM_THRESHOLD=0.95
